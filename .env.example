# Environment variables declared in this file are automatically made available to Prisma and Nx.
# Prisma Details: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema
# Nx Details: https://nx.dev/recipes/environment-variables/define-environment-variables

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# We are using a sqlite db, and the file path will be relative to the schema the env var is being used in.
DATABASE_URL="file:./dev.db"
